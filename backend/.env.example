# ===== 数据库 =====
# PostgreSQL 连接字符串（本地开发）
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/ai_math_teacher

# ===== JWT =====
# 生产环境请使用 64 位以上随机字符串
# 生成命令：node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ===== 服务器 =====
PORT=4000
NODE_ENV=development
# 允许的前端域名，多个用逗号分隔
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# ===== AI 供应商 Key（在这里集中管理，前端不再需要填写）=====
# 通义千问 / 阿里百炼
ALIYUN_API_KEY=sk-your-aliyun-key
ALIYUN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 智谱 GLM
ZHIPU_API_KEY=your-zhipu-key
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# DeepSeek
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# OpenAI（如果有梯子可用）
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1

# Gemini（Google）
GEMINI_API_KEY=your-gemini-key

# ===== 用量配额（每日） =====
# 免费用户每天最多发起的 AI 请求数
FREE_DAILY_QUOTA=10
# 付费用户每天最多发起的 AI 请求数
PAID_DAILY_QUOTA=500

# ===== 管理员 =====
# 初始管理员邮箱（注册后自动提升为 admin）
ADMIN_EMAILS=admin@example.com
